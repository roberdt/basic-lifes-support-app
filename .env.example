# SMTP settings for sending registration access requests
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-real-password

# Admin inbox to receive access requests
ADMIN_EMAIL=admin@example.com

# Optional: sender address shown in admin inbox
FROM_EMAIL=Basic Life Support <mailer@example.com>

